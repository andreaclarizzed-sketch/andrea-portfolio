---
import site from '../../content/site.json';

export function getStaticPaths() {
  return site.projects
    .filter((p: any) => p.slug && p.detail)
    .map((p: any) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const d = project.detail;
const isCategory = d.isCategory && d.subProjects;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{project.title} — Andrea Clarizze Dalay</title>
<meta name="description" content={d.overview} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style is:global>
:root{--cream:#F4EFE7;--card:#FFFFFF;--card-dark:#1E1B17;--ink:#1E1B17;--muted:#7C766C;--line:#EAE3D5;--accent:#8A6E4B;--page-bg:#FAFAF8;--sans:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;--serif:'Instrument Serif',Georgia,serif;--radius:24px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--page-bg);color:var(--ink);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.page{max-width:1040px;margin:0 auto;padding:32px 24px 80px}
.back{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:48px;transition:color .2s}
.back:hover{color:var(--accent)}
.eyebrow{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:24px}
h1{font-family:var(--serif);font-size:clamp(40px,6vw,76px);font-weight:400;letter-spacing:-.025em;line-height:1.05;margin-bottom:32px}
.meta-row{display:flex;flex-wrap:wrap;gap:24px;padding:20px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-bottom:56px;font-size:13px;color:var(--muted)}
.meta-row b{color:var(--ink);font-weight:600;display:block;margin-bottom:4px;font-size:11px;letter-spacing:.12em;text-transform:uppercase}
.section{margin-bottom:64px}
.section h2{font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:20px}
.section p{font-size:17px;color:var(--ink);line-height:1.7;max-width:760px}
.topline-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;background:var(--cream);padding:32px;border-radius:20px}
.topline-grid .n{font-size:32px;font-weight:700;color:var(--ink);letter-spacing:-.02em}
.topline-grid .l{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:6px}
.channels{width:100%;border-collapse:collapse}
.channels th{text-align:left;padding:14px 0;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;border-bottom:1px solid var(--line)}
.channels td{padding:18px 0;border-bottom:1px solid var(--line);font-size:15px}
.channels td:first-child{font-weight:500}
.channels td.num{color:var(--accent);font-weight:600}
ul.deliverables{list-style:none;padding:0}
ul.deliverables li{padding:14px 0 14px 28px;border-bottom:1px solid var(--line);font-size:15px;position:relative}
ul.deliverables li:before{content:"→";position:absolute;left:0;color:var(--accent);font-weight:600}
.note{padding:24px;background:var(--cream);border-radius:14px;font-size:14px;color:var(--muted);font-style:italic}
.source{font-size:12px;color:var(--muted);margin-top:24px;font-style:italic}

/* IMAGES */
.gallery{display:grid;gap:32px;margin-top:8px}
.shot{background:var(--card);border:1px solid var(--line);border-radius:18px;overflow:hidden}
.shot img{width:100%;display:block}
.shot .cap{padding:18px 22px;font-size:13px;color:var(--muted);line-height:1.55;border-top:1px solid var(--line);background:#FCFAF6}

/* SUB-PROJECTS (Category page) */
.sub-list{display:grid;gap:48px;margin-top:8px}
.subproj{background:var(--card);border:1px solid var(--line);border-radius:24px;padding:40px;display:grid;gap:28px}
.subproj-head{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-wrap:wrap;padding-bottom:18px;border-bottom:1px solid var(--line)}
.subproj-head .left{flex:1;min-width:260px}
.subproj-head .num{font-size:11px;color:var(--accent);letter-spacing:.18em;font-weight:600;margin-bottom:10px;text-transform:uppercase}
.subproj-head h3{font-family:var(--serif);font-size:32px;font-weight:400;color:var(--text);line-height:1.15;letter-spacing:-.015em;margin-bottom:6px}
.subproj-head .cat{font-size:13px;color:var(--muted);font-style:italic}
.subproj-head .src{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);padding:7px 14px;border:1px solid var(--line);border-radius:99px;white-space:nowrap;background:var(--cream)}
.subproj .ovr{font-size:15px;color:var(--ink);line-height:1.7;max-width:780px}
.subproj h4{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:16px}
.subproj .results-block{background:var(--cream);border-radius:16px;padding:24px;border:1px solid var(--line)}
.subproj .results-block ul{list-style:none;padding:0;margin:0}
.subproj .results-block li{padding:8px 0 8px 22px;font-size:14px;color:var(--ink);position:relative;line-height:1.55}
.subproj .results-block li:before{content:"●";position:absolute;left:0;color:var(--accent);font-size:10px;top:14px}
.subproj .img-block{margin-top:8px}
.subproj .img-block img{width:100%;display:block;border-radius:14px;border:1px solid var(--line)}
.subproj .img-block .cap{font-size:12px;color:var(--muted);margin-top:10px;font-style:italic}
.subproj .snote{padding:18px 22px;background:var(--cream);border-radius:12px;font-size:13px;color:var(--muted);font-style:italic;border-left:3px solid var(--accent)}

@media (max-width:720px){
  .topline-grid{grid-template-columns:repeat(2,1fr)}
  .channels th:nth-child(4),.channels td:nth-child(4){display:none}
  .subproj{padding:28px 22px}
}
</style>
</head>
<body>
<div class="page">
  <a class="back" href="/#work">← Back to Projects</a>
  <div class="eyebrow">{project.number} — {project.category}</div>
  <h1>{project.title}</h1>

  <div class="meta-row">
    <div style="flex:1;min-width:200px"><b>Client</b>{d.client}</div>
    <div style="flex:1;min-width:200px"><b>Role</b>{d.role}</div>
    <div style="flex:1;min-width:140px"><b>Date Range</b>{d.dateRange}</div>
  </div>

  <div class="section">
    <h2>Overview</h2>
    <p>{d.overview}</p>
  </div>

  {isCategory && (
    <div class="section">
      <h2>The Three Brands</h2>
      <div class="sub-list">
        {d.subProjects.map((sp: any) => (
          <div class="subproj">
            <div class="subproj-head">
              <div class="left">
                <div class="num">{sp.num} — {sp.category}</div>
                <h3>{sp.title}</h3>
              </div>
              <div class="src">{sp.source}</div>
            </div>
            <div class="ovr">{sp.overview}</div>

            <div>
              <h4>Deliverables</h4>
              <ul class="deliverables">
                {sp.deliverables.map((it: string) => <li>{it}</li>)}
              </ul>
            </div>

            {sp.image && (
              <div class="img-block">
                <h4>Live Snapshot (redacted)</h4>
                <img src={sp.image} alt={sp.title} />
                {sp.imageCaption && <div class="cap">{sp.imageCaption}</div>}
              </div>
            )}

            {sp.results && (
              <div>
                <h4>{sp.resultsHeadline || 'Results'}</h4>
                <div class="results-block">
                  <ul>
                    {sp.results.map((r: string) => <li>{r}</li>)}
                  </ul>
                </div>
                {sp.source && <div class="source">{sp.source}</div>}
              </div>
            )}

            {sp.samplesNote && <div class="snote">{sp.samplesNote}</div>}
          </div>
        ))}
      </div>
    </div>
  )}

  {!isCategory && (
    <>
      <div class="section">
        <h2>Topline Results</h2>
        <div class="topline-grid">
          {d.topline.map((t: any) => (
            <div><div class="n">{t.value}</div><div class="l">{t.label}</div></div>
          ))}
        </div>
        <div class="source">{d.source}</div>
      </div>

      <div class="section">
        <h2>Channel / Performance Breakdown</h2>
        <table class="channels">
          <thead><tr><th>Item</th><th>Value</th><th>Conversion</th><th>Notes</th></tr></thead>
          <tbody>
            {d.channels.map((c: any) => (
              <tr><td>{c.channel}</td><td class="num">{c.revenue}</td><td>{c.cvr}</td><td>{c.share}</td></tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="section">
        <h2>Approach</h2>
        <p>{d.approach}</p>
      </div>

      <div class="section">
        <h2>Deliverables</h2>
        <ul class="deliverables">
          {d.deliverables.map((item: string) => <li>{item}</li>)}
        </ul>
      </div>

      {d.images && d.images.length > 0 && (
        <div class="section">
          <h2>Dashboards &amp; Snapshots</h2>
          <div class="gallery">
            {d.images.map((img: any) => (
              <div class="shot">
                <img src={img.src} alt={img.caption} />
                <div class="cap">{img.caption}</div>
              </div>
            ))}
          </div>
        </div>
      )}
    </>
  )}

  {d.samplesNote && (
    <div class="section">
      <div class="note">{d.samplesNote}</div>
    </div>
  )}

  <a class="back" href="/#work">← Back to Projects</a>
</div>
</body>
</html>
