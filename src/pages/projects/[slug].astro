---
import site from '../../content/site.json';

export function getStaticPaths() {
  return site.projects
    .filter((p: any) => p.slug && p.detail)
    .map((p: any) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const d = project.detail;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{project.title} — Andrea Clarizze Dalay</title>
<meta name="description" content={d.overview} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
:root{--cream:#F2EDE5;--card:#FFFFFF;--card-dark:#1E1B17;--ink:#1E1B17;--muted:#8A8278;--line:#EDE6D9;--accent:#8A6E4B;--page-bg:#FAFAF8;--sans:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;--radius:28px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--page-bg);color:var(--ink);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;background-image:radial-gradient(ellipse 80% 50% at top,rgba(201,183,156,.18),transparent 70%);background-attachment:fixed}
a{color:inherit;text-decoration:none}
.page{max-width:980px;margin:0 auto;padding:32px 24px 80px}
.back{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:48px;transition:color .2s}
.back:hover{color:var(--accent)}
.eyebrow{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:24px}
h1{font-size:clamp(36px,5.5vw,64px);font-weight:700;letter-spacing:-.025em;line-height:1.05;margin-bottom:32px}
.meta-row{display:flex;flex-wrap:wrap;gap:24px;padding:20px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-bottom:48px;font-size:13px;color:var(--muted)}
.meta-row b{color:var(--ink);font-weight:600;display:block;margin-bottom:4px;font-size:11px;letter-spacing:.12em;text-transform:uppercase}
.section{margin-bottom:56px}
.section h2{font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:20px}
.section p{font-size:17px;color:var(--ink);line-height:1.7;max-width:760px}
.topline-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;background:var(--cream);padding:32px;border-radius:20px}
.topline-grid .n{font-size:32px;font-weight:700;color:var(--ink);letter-spacing:-.02em}
.topline-grid .l{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-top:6px}
.channels{width:100%;border-collapse:collapse}
.channels th{text-align:left;padding:14px 0;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;border-bottom:1px solid var(--line)}
.channels td{padding:18px 0;border-bottom:1px solid var(--line);font-size:15px}
.channels td:first-child{font-weight:500}
.channels td.num{color:var(--accent);font-weight:600}
ul.deliverables{list-style:none;padding:0}
ul.deliverables li{padding:14px 0 14px 28px;border-bottom:1px solid var(--line);font-size:15px;position:relative}
ul.deliverables li:before{content:"→";position:absolute;left:0;color:var(--accent);font-weight:600}
.note{padding:24px;background:var(--cream);border-radius:14px;font-size:14px;color:var(--muted);font-style:italic}
.source{font-size:12px;color:var(--muted);margin-top:24px;font-style:italic}
@media (max-width:720px){.topline-grid{grid-template-columns:repeat(2,1fr)}.channels th:nth-child(4),.channels td:nth-child(4){display:none}}
</style>
</head>
<body>
<div class="page">
  <a class="back" href="/#work">← Back to Projects</a>
  <div class="eyebrow">{project.number} — {project.category}</div>
  <h1>{project.title}</h1>

  <div class="meta-row">
    <div style="flex:1;min-width:200px"><b>Client</b>{d.client}</div>
    <div style="flex:1;min-width:200px"><b>Role</b>{d.role}</div>
    <div style="flex:1;min-width:140px"><b>Date Range</b>{d.dateRange}</div>
  </div>

  <div class="section">
    <h2>Overview</h2>
    <p>{d.overview}</p>
  </div>

  <div class="section">
    <h2>Topline Results</h2>
    <div class="topline-grid">
      {d.topline.map((t: any) => (
        <div><div class="n">{t.value}</div><div class="l">{t.label}</div></div>
      ))}
    </div>
    <div class="source">{d.source}</div>
  </div>

  <div class="section">
    <h2>Channel Performance</h2>
    <table class="channels">
      <thead><tr><th>Channel</th><th>Revenue</th><th>Conversion</th><th>Share</th></tr></thead>
      <tbody>
        {d.channels.map((c: any) => (
          <tr><td>{c.channel}</td><td class="num">{c.revenue}</td><td>{c.cvr}</td><td>{c.share}</td></tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>Approach</h2>
    <p>{d.approach}</p>
  </div>

  <div class="section">
    <h2>Deliverables</h2>
    <ul class="deliverables">
      {d.deliverables.map((item: string) => <li>{item}</li>)}
    </ul>
  </div>

  {d.samplesNote && (
    <div class="section">
      <div class="note">{d.samplesNote}</div>
    </div>
  )}

  <a class="back" href="/#work">← Back to Projects</a>
</div>
</body>
</html>
