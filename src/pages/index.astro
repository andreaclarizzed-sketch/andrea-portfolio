---
import site from '../content/site.json';
const { hero, projects, services, experience, samples, contact, footer, process, tools } = site;
const copyProjects = projects.filter((p: any) => p.roleSection === 'copy');
const seoProjects = projects.filter((p: any) => p.roleSection === 'seo');
const industries = ["Health & Wellness (DTC)", "Medical Tourism", "OBGYN / Multi-Location", "Supplements", "Dental", "B2B SaaS", "Automotive Aftermarket", "Pain Relief / Compression", "Local Service Brands"];
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Andrea Clarizze Dalay — Direct Response Copywriter & SEO Specialist</title>
<meta name="description" content={hero.tagline} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style is:global>
:root{
  --bg:#FAFAF8;
  --card:#FFFFFF;
  --cream:#F4EFE7;
  --dark:#141312;
  --ink:#1E1B17;
  --text:#1E1B17;
  --muted:#7C766C;
  --line:#EAE3D5;
  --accent:#8A6E4B;
  --accent-2:#C9B79C;
  --sans:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  --serif:'Instrument Serif', Georgia, serif;
  --radius:24px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

/* Scroll-triggered fade-up animation */
@media (prefers-reduced-motion:no-preference){
  .reveal{opacity:0;transform:translateY(28px);transition:opacity .8s cubic-bezier(.2,.8,.2,1), transform .8s cubic-bezier(.2,.8,.2,1)}
  .reveal.in-view{opacity:1;transform:translateY(0)}
  .reveal.delay-1{transition-delay:.08s}
  .reveal.delay-2{transition-delay:.16s}
  .reveal.delay-3{transition-delay:.24s}
  .reveal.delay-4{transition-delay:.32s}
}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:18px;line-height:1.7;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}

.wrap{max-width:1440px;margin:0 auto;padding:0 32px}

/* TOP NAV */
.topnav{padding:28px 0;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line);position:sticky;top:0;background:rgba(250,250,248,.92);backdrop-filter:blur(12px);z-index:100}
.brand{display:flex;align-items:center;gap:10px;font-weight:600;font-size:15px;letter-spacing:-.01em}
.brand .mark{width:32px;height:32px;border-radius:50%;background:var(--dark);color:var(--bg);display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;font-size:18px;font-weight:400}
.navlinks{display:flex;gap:36px;font-size:16px;color:var(--muted)}
.navlinks a{transition:color .2s}
.navlinks a:hover{color:var(--text)}
.book{background:var(--dark);color:#fff;padding:12px 22px;border-radius:99px;font-size:15px;font-weight:500;display:inline-flex;align-items:center;gap:8px;transition:all .25s}
.book:hover{background:var(--accent);transform:translateY(-1px)}
@media (max-width:820px){.navlinks{display:none}}

/* HERO */
.hero{padding:60px 0 80px;position:relative}
.hero-inner{display:grid;grid-template-columns:1.1fr 1fr;gap:48px;align-items:end}
.hero-left{padding-bottom:24px}
.hero-tag{display:inline-flex;align-items:center;gap:10px;font-size:18px;color:var(--text);font-weight:500;letter-spacing:-.01em;margin-bottom:28px}
.hero-tag::before{content:"";width:6px;height:6px;border-radius:50%;background:#52B788;box-shadow:0 0 0 4px rgba(82,183,136,.18);animation:pulse 2s infinite}
@keyframes pulse{50%{box-shadow:0 0 0 8px rgba(82,183,136,0)}}
.stat-strip{display:flex;gap:40px;margin-bottom:36px}
.stat-strip .s{}
.stat-strip .v{font-size:32px;font-weight:600;letter-spacing:-.02em;color:var(--text)}
.stat-strip .v em{color:var(--accent);font-style:normal}
.stat-strip .l{font-size:14px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:4px}
.hello{font-family:var(--serif);font-size:clamp(72px,12vw,180px);font-weight:400;line-height:.92;letter-spacing:-.025em;color:var(--text);margin-bottom:20px}
.hello em{font-style:italic;color:var(--accent)}
.hello-sub{font-size:17px;color:var(--muted);max-width:560px;line-height:1.75;margin-bottom:40px}
.hello-sub b{color:var(--text);font-weight:600}
.scroll{display:inline-flex;align-items:center;gap:10px;font-size:14px;color:var(--muted);letter-spacing:.05em;text-transform:uppercase}
.scroll .dot{width:32px;height:32px;border-radius:50%;border:1px solid var(--line);display:inline-flex;align-items:center;justify-content:center;transition:all .25s}
.scroll:hover .dot{background:var(--accent);border-color:var(--accent);color:#fff}
.hero-right{position:relative;aspect-ratio:4/5;background:var(--cream);border-radius:var(--radius);overflow:hidden}
.hero-right::after{content:"";position:absolute;inset:0;background:url('/photo.png') center 10% / cover no-repeat;filter:contrast(1.02) saturate(1.04)}
@media (max-width:820px){.hero-inner{grid-template-columns:1fr;gap:24px}.hero-right{aspect-ratio:1/1;max-width:380px;margin:0 auto}.stat-strip{gap:24px}.stat-strip .v{font-size:22px}}

/* ABOUT */
.about{padding:80px 0;border-top:1px solid var(--line)}
.about-grid{display:grid;grid-template-columns:1fr 1.1fr 1fr;gap:32px;align-items:start}
.about-eyebrow{font-size:15px;letter-spacing:.05em;font-weight:600;color:var(--text);margin-bottom:16px}
.about-text{font-size:16px;color:var(--muted);line-height:1.7;position:relative;padding-right:24px}
.about-text .doodle{position:absolute;right:-10px;top:80%;font-family:var(--serif);color:var(--accent);font-style:italic;font-size:48px;transform:rotate(20deg)}
.stat-card{background:var(--cream);border-radius:20px;padding:36px 28px;text-align:center;position:relative}
.stat-card .badge{width:48px;height:48px;border-radius:50%;background:#fff;display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;color:var(--accent);font-size:22px;margin-bottom:18px;border:1px solid var(--line)}
.stat-card .bignum{font-size:64px;font-weight:600;letter-spacing:-.03em;color:var(--text);line-height:1}
.stat-card .bigtxt{font-size:17px;color:var(--muted);margin-top:14px;line-height:1.5}
.stat-card .mini-portrait{width:120px;height:120px;border-radius:14px;background:var(--cream);background-image:url('/photo.png');background-size:cover;background-position:center;margin:24px auto 0;filter:saturate(1.05)}
.about-right{display:flex;flex-direction:column;gap:18px;align-items:flex-start}
.about-right .head{width:56px;height:56px;border-radius:50%;background-image:url('/photo.png');background-size:cover;background-position:center;border:2px solid var(--cream)}
.about-bullet{display:flex;gap:14px;align-items:flex-start;font-size:17px;color:var(--muted);line-height:1.6}
.about-bullet::before{content:"→";color:var(--accent);font-weight:600;flex-shrink:0;margin-top:1px}
@media (max-width:960px){.about-grid{grid-template-columns:1fr;gap:32px}}

/* HIGHLIGHTS STRIP */
.highlights{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin:48px 0 16px;padding:0}
.hl-card{background:var(--cream);border:1px solid var(--line);border-radius:18px;padding:32px 28px;transition:all .25s}
.hl-card:hover{border-color:var(--accent);transform:translateY(-3px)}
.hl-card .hl-n{font-family:var(--serif);font-size:52px;font-weight:400;color:var(--text);letter-spacing:-.02em;line-height:1}
.hl-card .hl-n em{font-style:italic;color:var(--accent);font-weight:400}
.hl-card .hl-l{font-size:14px;color:var(--muted);letter-spacing:.04em;margin-top:14px;line-height:1.4}
@media (max-width:820px){.highlights{grid-template-columns:repeat(2,1fr)}.hl-card .hl-n{font-size:38px}}

/* PULL QUOTE */
.pullquote{margin:48px 0;padding:80px 56px;background:var(--card);border:1px solid var(--line);border-radius:var(--radius);position:relative;text-align:center}
.pullquote .pq-mark{position:absolute;top:24px;left:48px;font-family:var(--serif);font-size:140px;color:var(--accent-2);line-height:1;font-weight:400;opacity:.6}
.pullquote p{font-family:var(--serif);font-size:clamp(28px,4vw,44px);font-weight:400;line-height:1.25;letter-spacing:-.015em;color:var(--text);max-width:920px;margin:0 auto}
.pullquote p em{font-style:italic;color:var(--accent)}
.pullquote .pq-attr{margin-top:32px;font-size:14px;color:var(--muted);letter-spacing:.04em}
@media (max-width:820px){.pullquote{padding:60px 28px}.pullquote .pq-mark{font-size:90px;left:24px;top:14px}}

/* ROLE CARD SECTIONS (Copy / SEO / Samples) */
.rolecard{background:var(--card);border-radius:var(--radius);padding:64px 56px;margin:32px 0;position:relative;overflow:hidden;box-shadow:0 1px 0 rgba(0,0,0,.02),0 30px 60px -30px rgba(30,27,23,.1);border:1px solid var(--line)}
.rolecard.dark{background:var(--dark);color:#EFE7DA;border-color:#2A2520}
.rolecard.dark .rolecard-label{color:#EFE7DA}
.rolecard.dark .rolecard-ghost{-webkit-text-stroke-color:rgba(255,255,255,.06)}
.rolecard.dark .work-item{background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08);color:#EFE7DA}
.rolecard.dark .work-item:hover{border-color:var(--accent-2);background:rgba(255,255,255,.06)}
.rolecard.dark .work-title{color:#EFE7DA}
.rolecard.dark .work-desc{color:rgba(239,231,218,.65)}
.rolecard.dark .work-num{color:var(--accent-2)}
.rolecard.dark .work-tags span{background:transparent;border-color:rgba(255,255,255,.15);color:rgba(239,231,218,.65)}
.rolecard.dark .work-meta{color:rgba(239,231,218,.55);border-color:rgba(255,255,255,.08)}
.rolecard.dark .work-meta .arrow{background:var(--accent-2);color:var(--dark)}
.rolecard.dark .work-item:hover .arrow{background:#fff}
.work-item.no-link{cursor:default}
.work-item.no-link:hover{transform:none;box-shadow:none}
.rolecard.dark .work-item.no-link:hover{border-color:rgba(255,255,255,.08);background:rgba(255,255,255,.04)}
/* EDITORIAL LIGHT SECTIONS — now boxed cards */
.editorial-section{background:var(--card);border-radius:var(--radius);padding:72px 56px;margin:32px 0;border:1px solid var(--line);position:relative;overflow:hidden;box-shadow:0 1px 0 rgba(0,0,0,.02),0 30px 60px -30px rgba(30,27,23,.1)}
.editorial-section.tinted{background:var(--cream)}
.editorial-section.dark-tinted{background:var(--dark);color:#EFE7DA}
.editorial-section.dark-tinted .editorial-h2{color:#EFE7DA}
.editorial-section.dark-tinted .eyebrow-dot{color:rgba(255,255,255,.6)}
.editorial-section.dark-tinted .ed-step{background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08)}
.editorial-section.dark-tinted .ed-step:hover{border-color:var(--accent-2);background:rgba(255,255,255,.06)}
.editorial-section.dark-tinted .ed-step .ed-st{color:#EFE7DA}
.editorial-section.dark-tinted .ed-step .ed-sd{color:rgba(239,231,218,.65)}
.editorial-section.dark-tinted .ed-step .ed-sn{color:var(--accent-2)}
.editorial-section.dark-tinted .ed-tools-col h4{color:var(--accent-2);border-color:rgba(255,255,255,.1)}
.editorial-section.dark-tinted .ed-tools-col li{color:#EFE7DA;border-bottom:1px solid rgba(255,255,255,.06)}
.section-ghost{position:absolute;top:30px;font-weight:700;font-size:clamp(100px,15vw,200px);letter-spacing:-.04em;line-height:.85;color:transparent;-webkit-text-stroke:1.5px rgba(138,110,75,.12);pointer-events:none;user-select:none;white-space:nowrap;z-index:0;font-family:var(--sans)}
.editorial-section.dark-tinted .section-ghost{-webkit-text-stroke-color:rgba(255,255,255,.06)}
.editorial-section > *:not(.section-ghost){position:relative;z-index:2}
.editorial-head{display:flex;flex-direction:column;align-items:flex-start;gap:14px;margin-bottom:48px;max-width:760px}
.editorial-head .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:17px;color:var(--muted)}
.editorial-head .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.editorial-h2{font-family:var(--serif);font-size:clamp(32px,4.5vw,52px);font-weight:400;line-height:1.05;letter-spacing:-.02em;color:var(--text)}
.ed-steps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.ed-step{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:28px;transition:all .25s}
.ed-step:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 20px 40px -20px rgba(30,27,23,.1)}
.ed-step .ed-sn{font-size:11px;color:var(--accent);letter-spacing:.18em;font-weight:600;margin-bottom:14px;text-transform:uppercase}
.ed-step .ed-st{font-family:var(--serif);font-size:22px;font-weight:400;margin-bottom:10px;letter-spacing:-.01em;color:var(--text)}
.ed-step .ed-sd{font-size:17px;color:var(--muted);line-height:1.7}
.ed-tools-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
.ed-tools-col h4{font-family:var(--sans);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:18px;font-weight:600;padding-bottom:12px;border-bottom:1px solid var(--line)}
.ed-tools-col ul{list-style:none}
.ed-tools-col li{padding:9px 0;font-size:15px;color:var(--text)}

/* PROOF GRID */
.proof-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:12px}
.proof-card{background:var(--cream);border:1px solid var(--line);border-radius:18px;overflow:hidden;transition:all .25s}
.proof-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 30px 60px -30px rgba(30,27,23,.18)}
.proof-card img{width:100%;height:240px;object-fit:cover;object-position:top center;display:block;border-bottom:1px solid var(--line)}
.proof-card .cap{padding:18px 22px;font-size:16px;color:var(--muted);line-height:1.5}
.proof-card .cap b{color:var(--text);font-weight:600;margin-right:4px}
@media (max-width:820px){.proof-grid{grid-template-columns:1fr}.proof-card img{height:180px}}

/* EXP grid — fixed layout, no wrapping issues */
.exp-icon{width:48px;height:48px;border-radius:50%;background:var(--accent);color:#fff;display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:18px;font-weight:400;font-style:italic;flex-shrink:0}
.exp-row{display:grid;grid-template-columns:64px minmax(200px,260px) minmax(0,1fr) minmax(180px,240px);gap:32px;padding:28px 0;border-bottom:1px solid rgba(30,27,23,.08);align-items:start}
.exp-row .left{font-size:17px;font-weight:600;color:var(--text);line-height:1.3}
.exp-row .left .dates{font-size:17px;color:var(--muted);font-weight:400;margin-top:6px;display:flex;align-items:center;gap:6px;white-space:nowrap}
.exp-row .left .dates::before{content:"";width:5px;height:5px;border-radius:50%;background:var(--accent)}
.exp-row .mid{font-size:16px;color:var(--muted);line-height:1.65}
.exp-row .tags{display:flex;gap:6px;flex-wrap:wrap;justify-content:flex-start;align-items:flex-start;align-self:center}
.exp-row .tags span{font-size:12px;letter-spacing:.04em;padding:6px 11px;border:1px solid var(--line);border-radius:99px;color:var(--muted);background:var(--card);white-space:nowrap}
@media (max-width:960px){.exp-row{grid-template-columns:48px 1fr;gap:14px}.exp-row .mid,.exp-row .tags{grid-column:1/-1;padding-left:62px}.exp-row .tags{justify-content:flex-start}}

/* BOTTOM SAMPLES SECTION */
.samples-bottom-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:48px;align-items:start}
.industries-eyebrow{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:18px}
.samples-thumb-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.samples-thumb{background:var(--card);border:1px solid var(--line);border-radius:14px;overflow:hidden;transition:all .25s}
.samples-thumb:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 20px 40px -20px rgba(30,27,23,.15)}
.samples-thumb img{width:100%;height:160px;object-fit:cover;object-position:top center;display:block}
.samples-thumb .cap{padding:12px 16px;font-size:17px;color:var(--muted);border-top:1px solid var(--line);background:#FCFAF6}
@media (max-width:820px){.samples-bottom-grid{grid-template-columns:1fr;gap:32px}}

/* CONTACT BANNER */
.contact-banner h3{font-family:var(--serif);font-size:clamp(40px,5.5vw,80px);font-weight:400;line-height:1.02;letter-spacing:-.025em}
.contact-banner h3 em{font-style:italic;color:var(--accent-2)}
.contact-banner{margin:24px 0 80px}
.banner-links{margin-top:22px;display:flex;flex-wrap:wrap;gap:20px;font-size:15px;color:rgba(255,255,255,.7);position:relative}
.banner-links a{color:rgba(255,255,255,.85);border-bottom:1px solid rgba(201,183,156,.4);padding-bottom:2px;transition:all .2s}
.banner-links a:hover{color:#fff;border-color:var(--accent-2)}

@media (max-width:820px){.ed-steps-grid{grid-template-columns:1fr}.ed-tools-grid{grid-template-columns:repeat(2,1fr);gap:24px}}
.rolecard-ghost{position:absolute;top:30px;left:-30px;font-family:var(--sans);font-weight:700;font-size:clamp(100px,15vw,200px);letter-spacing:-.04em;line-height:.85;color:transparent;-webkit-text-stroke:1.5px rgba(138,110,75,.12);pointer-events:none;user-select:none;white-space:nowrap;z-index:0}
.rolecard-label{font-size:18px;font-weight:600;letter-spacing:.01em;margin-bottom:48px;position:relative;z-index:2;color:var(--text)}
.rolecard-label .slash{color:var(--accent)}
.work-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;position:relative;z-index:2}
.work-grid.single{grid-template-columns:1fr}
.work-item{background:var(--cream);border-radius:20px;padding:36px;position:relative;transition:transform .3s ease,box-shadow .3s ease;border:1px solid var(--line);display:flex;flex-direction:column;gap:16px;min-height:320px;text-decoration:none;color:inherit}
.work-grid.single .work-item{display:grid;grid-template-columns:1.4fr 1fr;gap:32px;align-items:stretch;min-height:auto;padding:40px}
.work-grid.single .work-item .preview{background:#fff;border:1px solid var(--line);border-radius:14px;padding:24px;display:flex;flex-direction:column;justify-content:space-between;font-size:17px;color:var(--muted);line-height:1.55}
.work-grid.single .work-item .preview b{display:block;color:var(--text);font-size:16px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px;font-weight:600}
.work-grid.single .work-item .preview ul{list-style:none;padding:0;margin:0}
.work-grid.single .work-item .preview ul li{padding:7px 0 7px 18px;position:relative;border-bottom:1px dashed var(--line)}
.work-grid.single .work-item .preview ul li:last-child{border-bottom:none}
.work-grid.single .work-item .preview ul li:before{content:"•";position:absolute;left:0;color:var(--accent)}
.work-grid.single .work-item .left-body{display:flex;flex-direction:column;gap:16px}
@media (max-width:820px){.work-grid.single .work-item{grid-template-columns:1fr}}
.work-item:hover{transform:translateY(-4px);box-shadow:0 30px 60px -30px rgba(30,27,23,.25)}
.work-num{font-size:11px;color:var(--accent);letter-spacing:.18em;font-weight:600}
.work-title{font-family:var(--serif);font-size:26px;line-height:1.2;font-weight:400;letter-spacing:-.01em;color:var(--text)}
.work-desc{font-size:17px;color:var(--muted);line-height:1.65;flex-grow:1}
.work-meta{display:flex;justify-content:space-between;align-items:center;padding-top:16px;border-top:1px solid rgba(0,0,0,.06);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.work-meta .arrow{width:36px;height:36px;border-radius:50%;background:var(--dark);color:#fff;display:inline-flex;align-items:center;justify-content:center;transition:all .25s;font-size:16px}
.work-item:hover .arrow{background:var(--accent);transform:rotate(-10deg)}
.work-tags{display:flex;flex-wrap:wrap;gap:6px}
.work-tags span{font-size:10px;letter-spacing:.06em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--line);border-radius:99px;color:var(--muted);background:#fff}
.work-metric{font-size:15px;color:var(--accent);font-weight:600;letter-spacing:.02em}

/* SAMPLES BLOCK */
.samples-block{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:start;position:relative;z-index:2}
.cta-pill{display:inline-flex;align-items:center;gap:10px;background:var(--dark);color:#fff;padding:14px 26px;border-radius:99px;font-size:15px;font-weight:500;transition:all .3s}
.cta-pill:hover{background:var(--accent);transform:translateY(-2px);box-shadow:0 10px 30px -10px rgba(138,110,75,.6)}
.industries-grid{display:flex;flex-wrap:wrap;gap:8px}
.industry-pill{font-size:12px;padding:8px 14px;border:1px solid var(--line);border-radius:99px;color:var(--text);background:var(--cream);font-weight:500;transition:all .2s}
.industry-pill:hover{border-color:var(--accent);color:var(--accent)}
@media (max-width:820px){.rolecard{padding:36px 24px}.work-grid{grid-template-columns:1fr}.samples-block{grid-template-columns:1fr;gap:32px}.rolecard-ghost{font-size:70px}}

/* FEATURED STRIP (legacy unused) */
.featured{padding:32px 0 80px;overflow:hidden}
.featured-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.fcard{background:var(--cream);border-radius:20px;padding:32px;position:relative;overflow:hidden;aspect-ratio:1/1.05;display:flex;flex-direction:column;justify-content:space-between;transition:transform .3s ease}
.fcard:hover{transform:translateY(-4px)}
.fcard:nth-child(1){background:#F3EBDE}
.fcard:nth-child(2){background:#EAE3D5}
.fcard:nth-child(3){background:#F8F2E5}
.fcard .arrow{position:absolute;top:24px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--dark);color:#fff;display:inline-flex;align-items:center;justify-content:center;transition:all .3s}
.fcard:hover .arrow{background:var(--accent);transform:rotate(-12deg)}
.fcard .cat{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:14px}
.fcard h3{font-family:var(--serif);font-size:28px;line-height:1.15;font-weight:400;color:var(--text);margin-bottom:14px;letter-spacing:-.01em}
.fcard .desc{font-size:17px;color:var(--muted);line-height:1.55;margin-bottom:20px}
.fcard .metric{font-size:15px;color:var(--accent);font-weight:600;border-top:1px solid rgba(0,0,0,.06);padding-top:14px}
.fcard .author{font-size:14px;color:var(--muted);margin-top:18px}
@media (max-width:820px){.featured-grid{grid-template-columns:1fr}}

/* EXPERIENCE head */
.exp-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:36px;gap:24px;flex-wrap:wrap}
.exp-head .booklink{background:var(--dark);color:#fff;padding:14px 26px;border-radius:99px;font-size:15px;font-weight:500;display:inline-flex;gap:8px;align-items:center;transition:all .25s;white-space:nowrap}
.exp-head .booklink:hover{background:var(--accent);transform:translateY(-1px)}

/* CTA BANNER */
.banner{margin:80px 0;background:linear-gradient(105deg,#1E1B17 0%,#2A2520 100%);border-radius:24px;padding:60px;display:flex;justify-content:space-between;align-items:center;gap:32px;position:relative;overflow:hidden}
.banner::before{content:"";position:absolute;top:-50%;right:-10%;width:60%;height:200%;background:radial-gradient(ellipse,rgba(138,110,75,.3),transparent 60%);pointer-events:none}
.banner .b-eyebrow{font-size:11px;color:var(--accent-2);text-transform:uppercase;letter-spacing:.18em;margin-bottom:14px;position:relative}
.banner h3{font-family:var(--serif);font-size:clamp(28px,3.5vw,44px);color:#fff;font-weight:400;line-height:1.15;max-width:640px;position:relative}
.banner h3 em{font-style:italic;color:var(--accent-2)}
.banner .sub{font-size:15px;color:rgba(255,255,255,.55);margin-top:14px;max-width:520px;position:relative}
.banner .talk-btn{background:#fff;color:var(--dark);padding:16px 28px;border-radius:99px;font-size:15px;font-weight:500;display:inline-flex;align-items:center;gap:10px;transition:all .25s;white-space:nowrap;position:relative}
.banner .talk-btn:hover{background:var(--accent);color:#fff;transform:translateY(-2px)}
@media (max-width:820px){.banner{flex-direction:column;align-items:flex-start;padding:40px 28px}}

/* LATEST WORKS */
.latest{padding:80px 0}
.latest-head{text-align:center;margin-bottom:48px}
.latest-head .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:17px;color:var(--muted);margin-bottom:14px}
.latest-head .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.latest-head h2{font-family:var(--serif);font-size:clamp(36px,5vw,56px);font-weight:400;line-height:1.05;letter-spacing:-.02em}
.latest-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.lcard{background:var(--card);border:1px solid var(--line);border-radius:20px;overflow:hidden;transition:all .3s}
.lcard:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 30px 60px -30px rgba(30,27,23,.25)}
.lcard .thumb{aspect-ratio:5/3;background:linear-gradient(135deg,var(--cream),var(--accent-2));position:relative;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;color:rgba(255,255,255,.5);font-size:48px;overflow:hidden}
.lcard:nth-child(2) .thumb{background:linear-gradient(135deg,#E8B4A0,#C9876B)}
.lcard:nth-child(3) .thumb{background:linear-gradient(135deg,#C5D4C8,#7A9582)}
.lcard .thumb .corner{position:absolute;top:14px;right:14px;width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.9);color:var(--dark);display:flex;align-items:center;justify-content:center;font-size:16px}
.lcard .body{padding:24px}
.lcard .cat{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:8px}
.lcard h4{font-family:var(--serif);font-size:20px;font-weight:400;color:var(--text);line-height:1.25;letter-spacing:-.01em}
.see-more{display:flex;justify-content:center;margin-top:40px;font-size:17px;color:var(--muted)}
.see-more a{display:inline-flex;align-items:center;gap:10px;color:var(--text);font-weight:500;border-bottom:1px solid var(--accent);padding-bottom:4px;transition:color .2s}
.see-more a:hover{color:var(--accent)}
@media (max-width:820px){.latest-grid{grid-template-columns:1fr}}

/* SERVICES (replaces blog section) */
.servblog{padding:80px 0;border-top:1px solid var(--line)}
.servblog-head{text-align:center;margin-bottom:48px}
.servblog-head .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:17px;color:var(--muted);margin-bottom:14px}
.servblog-head .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.servblog-head h2{font-family:var(--serif);font-size:clamp(32px,4.5vw,48px);font-weight:400;line-height:1.05;letter-spacing:-.02em}
.serv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.scard{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:28px;transition:all .3s;display:flex;flex-direction:column;gap:14px;min-height:240px}
.scard:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:0 30px 60px -30px rgba(30,27,23,.15)}
.scard .icon{width:48px;height:48px;border-radius:14px;background:var(--cream);display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;color:var(--accent);font-size:22px}
.scard h4{font-family:var(--serif);font-size:22px;font-weight:400;color:var(--text);line-height:1.2;letter-spacing:-.01em}
.scard p{font-size:17px;color:var(--muted);line-height:1.55;flex-grow:1}
.scard .more{font-size:12px;color:var(--accent);letter-spacing:.06em;text-transform:uppercase;font-weight:600;display:inline-flex;align-items:center;gap:6px;margin-top:auto}
@media (max-width:820px){.serv-grid{grid-template-columns:1fr}}

/* FINAL CTA */
.finalcta{padding:100px 0 80px;text-align:center}
.finalcta .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:17px;color:var(--muted);margin-bottom:18px}
.finalcta .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.finalcta h2{font-family:var(--serif);font-size:clamp(40px,6vw,72px);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:18px}
.finalcta h2 em{font-style:italic;color:var(--accent)}
.finalcta .sub{font-size:16px;color:var(--muted);max-width:520px;margin:0 auto 32px;line-height:1.6}
.finalcta .talk-btn{background:var(--dark);color:#fff;padding:16px 30px;border-radius:99px;font-size:15px;font-weight:500;display:inline-flex;align-items:center;gap:10px;transition:all .3s}
.finalcta .talk-btn:hover{background:var(--accent);transform:translateY(-2px);box-shadow:0 14px 40px -10px rgba(138,110,75,.6)}

/* FOOTER */
footer.site{background:var(--dark);color:rgba(255,255,255,.7);padding:32px;border-radius:24px 24px 0 0;margin:0 32px;display:flex;justify-content:space-between;align-items:center;font-size:15px;gap:24px;flex-wrap:wrap}
footer.site .fbrand{display:flex;align-items:center;gap:10px;color:#fff;font-weight:600}
footer.site .fbrand .mark{width:32px;height:32px;border-radius:50%;background:#fff;color:var(--dark);display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;font-size:18px}
footer.site .fnav{display:flex;gap:28px;font-size:15px}
footer.site .fnav a:hover{color:#fff}
footer.site .femail{color:#fff;font-weight:500}
@media (max-width:720px){footer.site{flex-direction:column;align-items:flex-start;margin:0 16px}.fnav{flex-wrap:wrap;gap:18px}}
</style>
</head>
<body>

<div class="wrap">
  <nav class="topnav">
    <div class="brand"><span class="mark">a</span> Andrea Clarizze Dalay</div>
    <div class="navlinks">
      <a href="#work">Copywriting</a>
      <a href="#seo">SEO</a>
      <a href="#experience">Experience</a>
      <a href="#samples">Samples</a>
    </div>
    <a class="book" href={`mailto:${hero.email}`}>Email Me ↗</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-tag"><span style="width:8px;height:8px;border-radius:50%;background:#52B788;box-shadow:0 0 0 4px rgba(82,183,136,.18);display:inline-block"></span> Direct Response Copywriter &amp; SEO Specialist</div>
        <h1 class="hello">Hello<em>.</em></h1>
        <p class="hello-sub" set:html={hero.tagline.replace('I\'m Andrea — a', '<b>I\'m Andrea</b> — a')}></p>
        <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap">
          <a class="scroll" href="#work">Scroll down <span class="dot">↓</span></a>
          <a class="scroll" href="https://www.linkedin.com/in/andreaclarizzed/" target="_blank" rel="noopener" style="color:var(--text)">LinkedIn <span class="dot">↗</span></a>
        </div>
      </div>
      <div class="hero-right" aria-label="Andrea Clarizze Dalay"></div>
    </div>
  </section>

  <!-- DIRECT RESPONSE COPYWRITING -->
  <section class="rolecard reveal" id="work">
    <div class="rolecard-ghost">COPYWRITING</div>
    <div class="rolecard-label"><span class="slash">/</span>DIRECT RESPONSE COPYWRITING</div>
    <div class={copyProjects.length === 1 ? 'work-grid single' : 'work-grid'}>
      {copyProjects.map((p, i) => (
        <a class="work-item" href={p.link} target="_blank" rel="noopener">
          <div class="left-body">
            <div class="work-num">{String(i+1).padStart(2,'0')} — {p.category}</div>
            <div class="work-title">{p.title}</div>
            <div class="work-desc">{p.description}</div>
            <div class="work-tags">{p.tags.map((t: string) => <span>{t}</span>)}</div>
            <div class="work-metric">{p.metric}</div>
            <div class="work-meta"><span>{p.label}</span><span class="arrow">↗</span></div>
          </div>
          {copyProjects.length === 1 && (
            <div class="preview">
              <div>
                <b>Inside the category</b>
                <ul>
                  <li>DTC Health &amp; Wellness — Pain Relief / Compression</li>
                  <li>Men's Retail Store — Apparel / Chinos</li>
                  <li>High-End Skincare Retail — Multi-Brand</li>
                </ul>
              </div>
              <div style="font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;padding-top:14px;border-top:1px solid var(--line);margin-top:14px">3 brands · 1 category page →</div>
            </div>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- SEO SPECIALIST -->
  <section class="rolecard dark" id="seo">
    <div class="rolecard-ghost" style="right:-30px;left:auto">SEO</div>
    <div class="rolecard-label"><span class="slash">/</span>SEO SPECIALIST</div>
    <div class="work-grid">
      {seoProjects.map((p, i) => {
        const hasCase = p.slug && p.detail;
        const Tag = hasCase ? 'a' : 'div';
        const props = hasCase ? { class: 'work-item', href: p.link, target: '_blank', rel: 'noopener' } : { class: 'work-item no-link' };
        return (
          <Tag {...props}>
            <div class="left-body">
              <div class="work-num">{String(i+1).padStart(2,'0')} — {p.category}</div>
              <div class="work-title">{p.title}</div>
              <div class="work-desc">{p.description}</div>
              <div class="work-tags">{p.tags.map((t: string) => <span>{t}</span>)}</div>
              <div class="work-metric">{p.metric}</div>
              <div class="work-meta">
                <span>{hasCase ? p.label : 'OVERVIEW'}</span>
                {hasCase && <span class="arrow">↗</span>}
              </div>
            </div>
          </Tag>
        );
      })}
    </div>
  </section>

  <!-- PULL QUOTE (visual rest) -->
  <section class="pullquote reveal">
    <div class="pq-mark">"</div>
    <p>Not every SEO strategist can write copy that <em>converts.</em> Not every copywriter understands what makes a page <em>rank.</em> I work at the intersection — building the strategy and writing the words.</p>
    <div class="pq-attr">— How I think about the work</div>
  </section>

  <!-- EXPERIENCE -->
  <section class="editorial-section tinted" id="experience">
    <div class="section-ghost" style="right:-30px">JOURNEY</div>
    <div class="exp-head">
      <div>
        <div class="eyebrow-dot">Experience</div>
        <h2 class="editorial-h2">5+ years across DTC copy, SEO programs, and content strategy.</h2>
      </div>
      <a class="booklink" href={`mailto:${hero.email}`}>Email Me ↗</a>
    </div>
    {experience.map((e: any, i: number) => (
      <div class="exp-row">
        <div class="exp-icon">{String(i+1).padStart(2,'0')}</div>
        <div class="left">{e.company}<div class="dates">{e.date}</div></div>
        <div class="mid"><b style="display:block;color:var(--text);font-weight:600;font-size:15px;margin-bottom:6px">{e.role}</b>{e.summary}</div>
        <div class="tags">{e.tags && e.tags.map((t: string) => <span>{t}</span>)}</div>
      </div>
    ))}
  </section>


  <!-- HOW I WORK (DARK BOXED) -->
  <section class="editorial-section dark-tinted">
    <div class="section-ghost" style="left:-30px">PROCESS</div>
    <div class="editorial-head">
      <div class="eyebrow-dot">Process</div>
      <h2 class="editorial-h2">{process.title}</h2>
    </div>
    <div class="ed-steps-grid">
      {process.steps.map((s: any) => (
        <div class="ed-step">
          <div class="ed-sn">{s.number}</div>
          <div class="ed-st">{s.title}</div>
          <div class="ed-sd">{s.description}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROOF / DASHBOARDS IMAGE BLOCK -->
  <section class="editorial-section reveal">
    <div class="section-ghost" style="right:-30px">PROOF</div>
    <div class="editorial-head">
      <div class="eyebrow-dot">Proof</div>
      <h2 class="editorial-h2">Real dashboards. Real results.</h2>
      <p style="font-size:17px;color:var(--muted);line-height:1.7;max-width:680px;margin-top:8px">A selection of redacted client dashboards — Ahrefs, GA4, Semrush — from the projects above. Client domains and brand names blacked out for confidentiality.</p>
    </div>
    <div class="proof-grid">
      <div class="proof-card"><img src="/projects/seo-medtourism-before.png" alt="Medical Tourism — Ahrefs Before (redacted)" /><div class="cap"><b>Before</b> · Medical Tourism client · 6.2K keywords, 16.1K monthly traffic, declining post-HCU</div></div>
      <div class="proof-card"><img src="/projects/seo-medtourism-after.png" alt="Medical Tourism — Ahrefs After (redacted)" /><div class="cap"><b>After</b> · 11.5K keywords (+85%), 49.9K monthly traffic (+210%), 24 months in</div></div>
      <div class="proof-card"><img src="/projects/seo-obgyn-dashboard.png" alt="OBGYN Semrush Dashboard (redacted)" /><div class="cap"><b>OBGYN Clinic</b> · 44.93% visibility, 162 AI mentions, 150 cited pages across LLM surfaces</div></div>
      <div class="proof-card"><img src="/projects/seo-medtourism-keywords.png" alt="Top-ranking commercial dental keywords (redacted)" /><div class="cap"><b>Top-Ranking Keywords</b> · Page-1 commercial dental terms across the medical tourism program</div></div>
    </div>
  </section>

  <!-- WHAT I WORK WITH (TINTED BOXED) -->
  <section class="editorial-section tinted">
    <div class="section-ghost" style="left:-30px">STACK</div>
    <div class="editorial-head">
      <div class="eyebrow-dot">Stack</div>
      <h2 class="editorial-h2">What I work with.</h2>
    </div>
    <div class="ed-tools-grid">
      <div class="ed-tools-col"><h4>Technical SEO</h4><ul>{tools.technical.map((t: string) => <li>{t}</li>)}</ul></div>
      <div class="ed-tools-col"><h4>Keyword &amp; Strategy</h4><ul>{tools.keyword.map((t: string) => <li>{t}</li>)}</ul></div>
      <div class="ed-tools-col"><h4>Analytics</h4><ul>{tools.analytics.map((t: string) => <li>{t}</li>)}</ul></div>
      <div class="ed-tools-col"><h4>AI / GEO Stack</h4><ul>{tools.ai.map((t: string) => <li>{t}</li>)}</ul></div>
    </div>
  </section>

  <!-- SAMPLE WRITING PROJECTS (now at bottom, editorial) -->
  <section class="editorial-section reveal" id="samples">
    <div class="section-ghost" style="right:-30px">SAMPLES</div>
    <div class="editorial-head">
      <div class="eyebrow-dot">Samples</div>
      <h2 class="editorial-h2">Sample writing projects.</h2>
      <p style="font-size:17px;color:var(--muted);line-height:1.7;max-width:680px;margin-top:8px">A curated archive of writing samples across direct-response, SEO long-form, ads, and email — covering the industries I write for. Hosted in a private Drive folder for client confidentiality.</p>
    </div>
    <div class="samples-bottom-grid">
      <div class="samples-bottom-left">
        <div class="industries-eyebrow">Industries Written For</div>
        <div class="industries-grid">
          {industries.map(i => <span class="industry-pill">{i}</span>)}
        </div>
        <a class="cta-pill" href={contact.driveUrl} target="_blank" rel="noopener" style="margin-top:32px"><span>View Sample Writing Drive</span><span>↗</span></a>
      </div>
      <div class="samples-bottom-right">
        <div class="samples-thumb-grid">
          <div class="samples-thumb"><img src="/projects/ecom-frankster.png" alt="Men's retail brand sample (redacted)" /><div class="cap">Apparel / Men's Retail</div></div>
          <div class="samples-thumb"><img src="/projects/ecom-skincare.png" alt="Skincare brand sample (redacted)" /><div class="cap">Luxury Skincare</div></div>
          <div class="samples-thumb"><img src="/projects/seo-obgyn-services.png" alt="OBGYN service page (redacted)" /><div class="cap">Local Healthcare</div></div>
          <div class="samples-thumb"><img src="/projects/seo-medtourism-keywords.png" alt="Medical tourism keyword performance (redacted)" /><div class="cap">Medical Tourism</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT (BANNER STYLE LIKE CTA) -->
  <section class="wrap" id="contact" style="padding:0">
    <div class="banner contact-banner">
      <div>
        <div class="b-eyebrow">● Get in touch</div>
        <h3>Let's <em>talk.</em></h3>
        <div class="sub">{contact.subtitle}</div>
        <div class="banner-links">
          <a href={`mailto:${contact.email}`}>{contact.email} ↗</a>
          <a href={contact.linkedinUrl} target="_blank" rel="noopener">LinkedIn ↗</a>
          <a href={contact.driveUrl} target="_blank" rel="noopener">Drive ↗</a>
        </div>
      </div>
      <a class="talk-btn" href={`mailto:${contact.email}`}>Email Me ↗</a>
    </div>
  </section>
</div>

<footer class="site">
  <div class="fbrand"><span class="mark">a</span> Andrea Clarizze Dalay</div>
  <div class="fnav">
    <a href="#about">About</a>
    <a href="#work">Projects</a>
    <a href="#services">Services</a>
    <a href="#experience">Experience</a>
  </div>
  <a class="femail" href={`mailto:${contact.email}`}>{contact.email}</a>
</footer>

<script>
  (function(){
    if (!('IntersectionObserver' in window)) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('in-view'));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  })();
</script>
</body>
</html>
