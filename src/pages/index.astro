---
import site from '../content/site.json';
const { hero, projects, services, experience, samples, contact, footer } = site;
const copyProjects = projects.filter((p: any) => p.roleSection === 'copy');
const seoProjects = projects.filter((p: any) => p.roleSection === 'seo');
const industries = ["Health & Wellness (DTC)", "Medical Tourism", "OBGYN / Multi-Location", "Supplements", "Dental", "B2B SaaS", "Automotive Aftermarket", "Pain Relief / Compression", "Local Service Brands"];
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Andrea Clarizze Dalay — Direct Response Copywriter & SEO Specialist</title>
<meta name="description" content={hero.tagline} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style is:global>
:root{
  --bg:#FAFAF8;
  --card:#FFFFFF;
  --cream:#F4EFE7;
  --dark:#141312;
  --ink:#1E1B17;
  --text:#1E1B17;
  --muted:#7C766C;
  --line:#EAE3D5;
  --accent:#8A6E4B;
  --accent-2:#C9B79C;
  --sans:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  --serif:'Instrument Serif', Georgia, serif;
  --radius:24px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}

.wrap{max-width:1240px;margin:0 auto;padding:0 32px}

/* TOP NAV */
.topnav{padding:28px 0;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line);position:sticky;top:0;background:rgba(250,250,248,.92);backdrop-filter:blur(12px);z-index:100}
.brand{display:flex;align-items:center;gap:10px;font-weight:600;font-size:15px;letter-spacing:-.01em}
.brand .mark{width:32px;height:32px;border-radius:50%;background:var(--dark);color:var(--bg);display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;font-size:18px;font-weight:400}
.navlinks{display:flex;gap:36px;font-size:14px;color:var(--muted)}
.navlinks a{transition:color .2s}
.navlinks a:hover{color:var(--text)}
.book{background:var(--dark);color:#fff;padding:12px 22px;border-radius:99px;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:8px;transition:all .25s}
.book:hover{background:var(--accent);transform:translateY(-1px)}
@media (max-width:820px){.navlinks{display:none}}

/* HERO */
.hero{padding:60px 0 80px;position:relative}
.hero-inner{display:grid;grid-template-columns:1.1fr 1fr;gap:48px;align-items:end}
.hero-left{padding-bottom:24px}
.hero-tag{display:inline-flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);letter-spacing:.04em;margin-bottom:18px;text-transform:lowercase}
.hero-tag::before{content:"";width:6px;height:6px;border-radius:50%;background:#52B788;box-shadow:0 0 0 4px rgba(82,183,136,.18);animation:pulse 2s infinite}
@keyframes pulse{50%{box-shadow:0 0 0 8px rgba(82,183,136,0)}}
.stat-strip{display:flex;gap:40px;margin-bottom:36px}
.stat-strip .s{}
.stat-strip .v{font-size:32px;font-weight:600;letter-spacing:-.02em;color:var(--text)}
.stat-strip .v em{color:var(--accent);font-style:normal}
.stat-strip .l{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:4px}
.hello{font-family:var(--serif);font-size:clamp(72px,12vw,180px);font-weight:400;line-height:.92;letter-spacing:-.025em;color:var(--text);margin-bottom:20px}
.hello em{font-style:italic;color:var(--accent)}
.hello-sub{font-size:14px;color:var(--muted);max-width:380px;line-height:1.6;margin-bottom:40px}
.hello-sub b{color:var(--text);font-weight:500}
.scroll{display:inline-flex;align-items:center;gap:10px;font-size:12px;color:var(--muted);letter-spacing:.05em;text-transform:uppercase}
.scroll .dot{width:32px;height:32px;border-radius:50%;border:1px solid var(--line);display:inline-flex;align-items:center;justify-content:center;transition:all .25s}
.scroll:hover .dot{background:var(--accent);border-color:var(--accent);color:#fff}
.hero-right{position:relative;aspect-ratio:4/5;background:var(--cream);border-radius:var(--radius);overflow:hidden}
.hero-right::after{content:"";position:absolute;inset:0;background:url('/photo.png') center bottom / contain no-repeat;filter:contrast(1.02) saturate(1.04)}
@media (max-width:820px){.hero-inner{grid-template-columns:1fr;gap:24px}.hero-right{aspect-ratio:1/1;max-width:380px;margin:0 auto}.stat-strip{gap:24px}.stat-strip .v{font-size:22px}}

/* ABOUT */
.about{padding:80px 0;border-top:1px solid var(--line)}
.about-grid{display:grid;grid-template-columns:1fr 1.1fr 1fr;gap:32px;align-items:start}
.about-eyebrow{font-size:13px;letter-spacing:.05em;font-weight:600;color:var(--text);margin-bottom:16px}
.about-text{font-size:14px;color:var(--muted);line-height:1.7;position:relative;padding-right:24px}
.about-text .doodle{position:absolute;right:-10px;top:80%;font-family:var(--serif);color:var(--accent);font-style:italic;font-size:48px;transform:rotate(20deg)}
.stat-card{background:var(--cream);border-radius:20px;padding:36px 28px;text-align:center;position:relative}
.stat-card .badge{width:48px;height:48px;border-radius:50%;background:#fff;display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;color:var(--accent);font-size:22px;margin-bottom:18px;border:1px solid var(--line)}
.stat-card .bignum{font-size:64px;font-weight:600;letter-spacing:-.03em;color:var(--text);line-height:1}
.stat-card .bigtxt{font-size:13px;color:var(--muted);margin-top:14px;line-height:1.5}
.stat-card .mini-portrait{width:120px;height:120px;border-radius:14px;background:var(--cream);background-image:url('/photo.png');background-size:cover;background-position:center;margin:24px auto 0;filter:saturate(1.05)}
.about-right{display:flex;flex-direction:column;gap:18px;align-items:flex-start}
.about-right .head{width:56px;height:56px;border-radius:50%;background-image:url('/photo.png');background-size:cover;background-position:center;border:2px solid var(--cream)}
.about-bullet{display:flex;gap:14px;align-items:flex-start;font-size:13px;color:var(--muted);line-height:1.6}
.about-bullet::before{content:"→";color:var(--accent);font-weight:600;flex-shrink:0;margin-top:1px}
@media (max-width:960px){.about-grid{grid-template-columns:1fr;gap:32px}}

/* ROLE CARD SECTIONS (Copy / SEO / Samples) */
.rolecard{background:var(--card);border-radius:var(--radius);padding:64px 56px;margin:32px 0;position:relative;overflow:hidden;box-shadow:0 1px 0 rgba(0,0,0,.02),0 30px 60px -30px rgba(30,27,23,.1);border:1px solid var(--line)}
.rolecard-ghost{position:absolute;top:30px;left:-30px;font-family:var(--sans);font-weight:700;font-size:clamp(100px,15vw,200px);letter-spacing:-.04em;line-height:.85;color:transparent;-webkit-text-stroke:1.5px rgba(138,110,75,.12);pointer-events:none;user-select:none;white-space:nowrap;z-index:0}
.rolecard-label{font-size:18px;font-weight:600;letter-spacing:.01em;margin-bottom:48px;position:relative;z-index:2;color:var(--text)}
.rolecard-label .slash{color:var(--accent)}
.work-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;position:relative;z-index:2}
.work-item{background:var(--cream);border-radius:20px;padding:32px;position:relative;transition:transform .3s ease,box-shadow .3s ease;border:1px solid var(--line);display:flex;flex-direction:column;gap:16px;min-height:320px;text-decoration:none;color:inherit}
.work-item:hover{transform:translateY(-4px);box-shadow:0 30px 60px -30px rgba(30,27,23,.25)}
.work-num{font-size:11px;color:var(--accent);letter-spacing:.18em;font-weight:600}
.work-title{font-family:var(--serif);font-size:26px;line-height:1.2;font-weight:400;letter-spacing:-.01em;color:var(--text)}
.work-desc{font-size:13px;color:var(--muted);line-height:1.6;flex-grow:1}
.work-meta{display:flex;justify-content:space-between;align-items:center;padding-top:16px;border-top:1px solid rgba(0,0,0,.06);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.work-meta .arrow{width:36px;height:36px;border-radius:50%;background:var(--dark);color:#fff;display:inline-flex;align-items:center;justify-content:center;transition:all .25s;font-size:14px}
.work-item:hover .arrow{background:var(--accent);transform:rotate(-10deg)}
.work-tags{display:flex;flex-wrap:wrap;gap:6px}
.work-tags span{font-size:10px;letter-spacing:.06em;text-transform:uppercase;padding:5px 10px;border:1px solid var(--line);border-radius:99px;color:var(--muted);background:#fff}
.work-metric{font-size:13px;color:var(--accent);font-weight:600;letter-spacing:.02em}

/* SAMPLES BLOCK */
.samples-block{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:start;position:relative;z-index:2}
.cta-pill{display:inline-flex;align-items:center;gap:10px;background:var(--dark);color:#fff;padding:14px 26px;border-radius:99px;font-size:13px;font-weight:500;transition:all .3s}
.cta-pill:hover{background:var(--accent);transform:translateY(-2px);box-shadow:0 10px 30px -10px rgba(138,110,75,.6)}
.industries-grid{display:flex;flex-wrap:wrap;gap:8px}
.industry-pill{font-size:12px;padding:8px 14px;border:1px solid var(--line);border-radius:99px;color:var(--text);background:var(--cream);font-weight:500;transition:all .2s}
.industry-pill:hover{border-color:var(--accent);color:var(--accent)}
@media (max-width:820px){.rolecard{padding:36px 24px}.work-grid{grid-template-columns:1fr}.samples-block{grid-template-columns:1fr;gap:32px}.rolecard-ghost{font-size:70px}}

/* FEATURED STRIP (legacy unused) */
.featured{padding:32px 0 80px;overflow:hidden}
.featured-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.fcard{background:var(--cream);border-radius:20px;padding:32px;position:relative;overflow:hidden;aspect-ratio:1/1.05;display:flex;flex-direction:column;justify-content:space-between;transition:transform .3s ease}
.fcard:hover{transform:translateY(-4px)}
.fcard:nth-child(1){background:#F3EBDE}
.fcard:nth-child(2){background:#EAE3D5}
.fcard:nth-child(3){background:#F8F2E5}
.fcard .arrow{position:absolute;top:24px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--dark);color:#fff;display:inline-flex;align-items:center;justify-content:center;transition:all .3s}
.fcard:hover .arrow{background:var(--accent);transform:rotate(-12deg)}
.fcard .cat{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:14px}
.fcard h3{font-family:var(--serif);font-size:28px;line-height:1.15;font-weight:400;color:var(--text);margin-bottom:14px;letter-spacing:-.01em}
.fcard .desc{font-size:13px;color:var(--muted);line-height:1.55;margin-bottom:20px}
.fcard .metric{font-size:13px;color:var(--accent);font-weight:600;border-top:1px solid rgba(0,0,0,.06);padding-top:14px}
.fcard .author{font-size:12px;color:var(--muted);margin-top:18px}
@media (max-width:820px){.featured-grid{grid-template-columns:1fr}}

/* EXPERIENCE */
.exp{padding:80px 0;border-top:1px solid var(--line)}
.exp-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:48px;gap:24px}
.exp-head .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:12px}
.exp-head .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.exp-head h2{font-family:var(--serif);font-size:clamp(36px,5vw,56px);font-weight:400;line-height:1.05;letter-spacing:-.02em;max-width:580px}
.exp-head .booklink{background:var(--dark);color:#fff;padding:14px 26px;border-radius:99px;font-size:13px;font-weight:500;display:inline-flex;gap:8px;align-items:center;transition:all .25s;white-space:nowrap}
.exp-head .booklink:hover{background:var(--accent);transform:translateY(-1px)}
.exp-row{display:grid;grid-template-columns:1.4fr 1.6fr auto;gap:32px;padding:28px 0;border-bottom:1px solid var(--line);align-items:center}
.exp-row .left{font-size:16px;font-weight:500;color:var(--text)}
.exp-row .left .dates{font-size:12px;color:var(--muted);font-weight:400;margin-top:4px;display:flex;align-items:center;gap:6px}
.exp-row .left .dates::before{content:"";width:5px;height:5px;border-radius:50%;background:var(--accent)}
.exp-row .mid{font-size:14px;color:var(--muted);line-height:1.55}
.exp-row .tags{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
.exp-row .tags span{font-size:11px;letter-spacing:.05em;padding:7px 14px;border:1px solid var(--line);border-radius:99px;color:var(--muted);background:var(--card)}
@media (max-width:820px){.exp-head{flex-direction:column;align-items:flex-start}.exp-row{grid-template-columns:1fr;gap:8px}.exp-row .tags{justify-content:flex-start}}

/* CTA BANNER */
.banner{margin:80px 0;background:linear-gradient(105deg,#1E1B17 0%,#2A2520 100%);border-radius:24px;padding:60px;display:flex;justify-content:space-between;align-items:center;gap:32px;position:relative;overflow:hidden}
.banner::before{content:"";position:absolute;top:-50%;right:-10%;width:60%;height:200%;background:radial-gradient(ellipse,rgba(138,110,75,.3),transparent 60%);pointer-events:none}
.banner .b-eyebrow{font-size:11px;color:var(--accent-2);text-transform:uppercase;letter-spacing:.18em;margin-bottom:14px;position:relative}
.banner h3{font-family:var(--serif);font-size:clamp(28px,3.5vw,44px);color:#fff;font-weight:400;line-height:1.15;max-width:640px;position:relative}
.banner h3 em{font-style:italic;color:var(--accent-2)}
.banner .sub{font-size:13px;color:rgba(255,255,255,.55);margin-top:14px;max-width:520px;position:relative}
.banner .talk-btn{background:#fff;color:var(--dark);padding:16px 28px;border-radius:99px;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:10px;transition:all .25s;white-space:nowrap;position:relative}
.banner .talk-btn:hover{background:var(--accent);color:#fff;transform:translateY(-2px)}
@media (max-width:820px){.banner{flex-direction:column;align-items:flex-start;padding:40px 28px}}

/* LATEST WORKS */
.latest{padding:80px 0}
.latest-head{text-align:center;margin-bottom:48px}
.latest-head .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:14px}
.latest-head .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.latest-head h2{font-family:var(--serif);font-size:clamp(36px,5vw,56px);font-weight:400;line-height:1.05;letter-spacing:-.02em}
.latest-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.lcard{background:var(--card);border:1px solid var(--line);border-radius:20px;overflow:hidden;transition:all .3s}
.lcard:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 30px 60px -30px rgba(30,27,23,.25)}
.lcard .thumb{aspect-ratio:5/3;background:linear-gradient(135deg,var(--cream),var(--accent-2));position:relative;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;color:rgba(255,255,255,.5);font-size:48px;overflow:hidden}
.lcard:nth-child(2) .thumb{background:linear-gradient(135deg,#E8B4A0,#C9876B)}
.lcard:nth-child(3) .thumb{background:linear-gradient(135deg,#C5D4C8,#7A9582)}
.lcard .thumb .corner{position:absolute;top:14px;right:14px;width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.9);color:var(--dark);display:flex;align-items:center;justify-content:center;font-size:14px}
.lcard .body{padding:24px}
.lcard .cat{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:8px}
.lcard h4{font-family:var(--serif);font-size:20px;font-weight:400;color:var(--text);line-height:1.25;letter-spacing:-.01em}
.see-more{display:flex;justify-content:center;margin-top:40px;font-size:13px;color:var(--muted)}
.see-more a{display:inline-flex;align-items:center;gap:10px;color:var(--text);font-weight:500;border-bottom:1px solid var(--accent);padding-bottom:4px;transition:color .2s}
.see-more a:hover{color:var(--accent)}
@media (max-width:820px){.latest-grid{grid-template-columns:1fr}}

/* SERVICES (replaces blog section) */
.servblog{padding:80px 0;border-top:1px solid var(--line)}
.servblog-head{text-align:center;margin-bottom:48px}
.servblog-head .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:14px}
.servblog-head .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.servblog-head h2{font-family:var(--serif);font-size:clamp(32px,4.5vw,48px);font-weight:400;line-height:1.05;letter-spacing:-.02em}
.serv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.scard{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:28px;transition:all .3s;display:flex;flex-direction:column;gap:14px;min-height:240px}
.scard:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:0 30px 60px -30px rgba(30,27,23,.15)}
.scard .icon{width:48px;height:48px;border-radius:14px;background:var(--cream);display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;color:var(--accent);font-size:22px}
.scard h4{font-family:var(--serif);font-size:22px;font-weight:400;color:var(--text);line-height:1.2;letter-spacing:-.01em}
.scard p{font-size:13px;color:var(--muted);line-height:1.55;flex-grow:1}
.scard .more{font-size:12px;color:var(--accent);letter-spacing:.06em;text-transform:uppercase;font-weight:600;display:inline-flex;align-items:center;gap:6px;margin-top:auto}
@media (max-width:820px){.serv-grid{grid-template-columns:1fr}}

/* FINAL CTA */
.finalcta{padding:100px 0 80px;text-align:center}
.finalcta .eyebrow-dot{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:18px}
.finalcta .eyebrow-dot::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
.finalcta h2{font-family:var(--serif);font-size:clamp(40px,6vw,72px);font-weight:400;line-height:1.05;letter-spacing:-.025em;margin-bottom:18px}
.finalcta h2 em{font-style:italic;color:var(--accent)}
.finalcta .sub{font-size:14px;color:var(--muted);max-width:520px;margin:0 auto 32px;line-height:1.6}
.finalcta .talk-btn{background:var(--dark);color:#fff;padding:16px 30px;border-radius:99px;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:10px;transition:all .3s}
.finalcta .talk-btn:hover{background:var(--accent);transform:translateY(-2px);box-shadow:0 14px 40px -10px rgba(138,110,75,.6)}

/* FOOTER */
footer.site{background:var(--dark);color:rgba(255,255,255,.7);padding:32px;border-radius:24px 24px 0 0;margin:0 32px;display:flex;justify-content:space-between;align-items:center;font-size:13px;gap:24px;flex-wrap:wrap}
footer.site .fbrand{display:flex;align-items:center;gap:10px;color:#fff;font-weight:600}
footer.site .fbrand .mark{width:32px;height:32px;border-radius:50%;background:#fff;color:var(--dark);display:inline-flex;align-items:center;justify-content:center;font-family:var(--serif);font-style:italic;font-size:18px}
footer.site .fnav{display:flex;gap:28px;font-size:13px}
footer.site .fnav a:hover{color:#fff}
footer.site .femail{color:#fff;font-weight:500}
@media (max-width:720px){footer.site{flex-direction:column;align-items:flex-start;margin:0 16px}.fnav{flex-wrap:wrap;gap:18px}}
</style>
</head>
<body>

<div class="wrap">
  <nav class="topnav">
    <div class="brand"><span class="mark">a</span> Andrea Clarizze Dalay</div>
    <div class="navlinks">
      <a href="#about">About</a>
      <a href="#work">Copywriting</a>
      <a href="#seo">SEO</a>
      <a href="#experience">Experience</a>
      <a href="#samples">Samples</a>
    </div>
    <a class="book" href={`mailto:${hero.email}`}>Book A Call ↗</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-tag">Direct Response Copywriter</div>
        <div class="stat-strip">
          <div class="s"><div class="v">+<em>$10M</em></div><div class="l">Revenue Generated</div></div>
          <div class="s"><div class="v">+<em>5</em></div><div class="l">Years Experience</div></div>
        </div>
        <h1 class="hello">Hello<em>.</em></h1>
        <p class="hello-sub"><b>I'm Andrea</b> — a direct response copywriter and SEO specialist building AI-native content systems for health, wellness, and DTC brands.</p>
        <a class="scroll" href="#about">Scroll down <span class="dot">↓</span></a>
      </div>
