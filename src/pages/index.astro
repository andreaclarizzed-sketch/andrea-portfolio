---
import site from '../content/site.json';
const { hero, stats, projects, services, experience, process, samples, tools, contact, footer } = site;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Andrea Clarizze Dalay — SEO Copywriter</title>
<meta name="description" content={hero.tagline} />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:global>
:root{--cream:#F2EDE5;--card:#FAF6F0;--card-dark:#1E1B17;--ink:#1E1B17;--muted:#8A8278;--line:#E3DBCE;--line-dark:#2E2A24;--accent:#8A6E4B;--accent-2:#C9B79C;--sans:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;--radius:28px}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--ink);font-family:var(--sans);font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased;background-image:radial-gradient(ellipse at top,rgba(138,110,75,.08),transparent 60%),radial-gradient(ellipse at bottom right,rgba(201,183,156,.18),transparent 50%);background-attachment:fixed}
a{color:inherit;text-decoration:none}
.page{max-width:1280px;margin:24px auto;padding:0 24px}
.card{background:var(--card);border-radius:var(--radius);padding:64px 72px;margin-bottom:24px;position:relative;overflow:hidden;box-shadow:0 1px 0 rgba(0,0,0,.02),0 30px 60px -30px rgba(30,27,23,.18)}
.card.dark{background:var(--card-dark);color:#EFE7DA}
nav.top{display:flex;align-items:center;justify-content:space-between;font-size:13px;letter-spacing:.02em;font-weight:400;margin-bottom:80px}
.avail{display:flex;align-items:center;gap:10px;color:var(--ink);font-weight:500}
.dot{width:8px;height:8px;border-radius:50%;background:#52B788;box-shadow:0 0 0 4px rgba(82,183,136,.18);animation:pulse 2s infinite}
@keyframes pulse{50%{box-shadow:0 0 0 8px rgba(82,183,136,0)}}
.navlinks{display:flex;gap:36px;color:var(--muted)}
.navlinks a{position:relative;transition:color .2s}
.navlinks a:hover{color:var(--ink)}
.navlinks sup{font-size:9px;color:var(--accent);margin-left:2px;font-weight:500}
.talk{border:1px solid var(--line);padding:10px 18px;border-radius:99px;display:inline-flex;align-items:center;gap:8px;font-weight:500;background:var(--card);transition:all .2s}
.talk:hover{background:var(--ink);color:var(--card);border-color:var(--ink)}
.card.dark .talk{border-color:var(--line-dark);background:transparent;color:#EFE7DA}
.ghost{position:absolute;font-weight:700;font-size:clamp(120px,18vw,260px);letter-spacing:-.04em;line-height:.85;color:transparent;-webkit-text-stroke:1.5px rgba(30,27,23,.08);pointer-events:none;user-select:none;white-space:nowrap}
.card.dark .ghost{-webkit-text-stroke-color:rgba(255,255,255,.06)}
.label{font-size:18px;font-weight:600;letter-spacing:.01em;margin-bottom:48px;position:relative;z-index:2}
.label .slash{color:var(--accent)}
.hero{padding-bottom:0;display:flex;flex-direction:column;position:relative}
.hero-stage{position:relative;margin-top:40px;display:flex;flex-direction:column;align-items:center}
.hero-name{position:relative;z-index:3;font-size:clamp(60px,12.5vw,200px);font-weight:700;line-height:.88;letter-spacing:-.05em;text-align:center;pointer-events:none;white-space:nowrap;width:100%}
.hero-portrait{position:relative;z-index:2;margin-top:-4vw;width:min(58%,560px);aspect-ratio:1/1.05;background-image:url('/photo.png');background-size:contain;background-repeat:no-repeat;background-position:center top;filter:contrast(1.03) saturate(1.05)}
.hero-name .outline{color:transparent;-webkit-text-stroke:1.5px var(--ink)}
.hero-name .fill{color:var(--ink)}
.hero-bottom{display:flex;justify-content:space-between;align-items:flex-end;gap:40px;position:relative;z-index:4;margin-top:-220px}
.hero-tagline{max-width:340px;font-size:14px;color:var(--muted);line-height:1.6}
.hero-tagline .role{font-size:22px;color:var(--ink);font-weight:600;margin-bottom:10px;letter-spacing:-.01em}
.hero-tagline .cta{margin-top:18px;display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:var(--card);padding:12px 22px;border-radius:99px;font-size:13px;font-weight:500;transition:transform .2s}
.hero-tagline .cta:hover{transform:translateY(-2px)}
.hero-socials{display:flex;flex-direction:column;gap:10px;align-items:flex-end}
.hero-socials a{border:1px solid var(--line);background:var(--card);padding:9px 16px;border-radius:99px;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:8px;transition:all .2s;min-width:130px;justify-content:flex-start}
.hero-socials a:hover{border-color:var(--accent);color:var(--accent);transform:translateX(-3px)}
.hero-socials a .ico{width:14px;display:inline-block;color:var(--accent)}
.results{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;padding:48px 0 8px;border-top:1px solid var(--line);margin-top:60px}
.results .n{font-size:44px;font-weight:600;letter-spacing:-.02em;color:var(--ink)}
.results .n em{color:var(--accent);font-style:normal}
.results .lbl{font-size:12px;color:var(--muted);margin-top:6px;letter-spacing:.04em;text-transform:uppercase}
.work-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;position:relative;z-index:2}
.work-item{background:#fff;border-radius:20px;padding:36px;position:relative;transition:transform .3s ease,box-shadow .3s ease;border:1px solid var(--line);display:flex;flex-direction:column;gap:18px;min-height:340px}
.work-item:hover{transform:translateY(-4px);box-shadow:0 30px 60px -30px rgba(30,27,23,.25)}
.work-num{font-size:12px;color:var(--accent);letter-spacing:.18em;font-weight:600}
.work-title{font-size:24px;line-height:1.2;font-weight:600;letter-spacing:-.01em}
.work-desc{font-size:14px;color:var(--muted);line-height:1.6;flex-grow:1}
.work-meta{display:flex;justify-content:space-between;align-items:center;padding-top:18px;border-top:1px solid var(--line);font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted)}
.work-meta .arrow{width:38px;height:38px;border-radius:50%;border:1px solid var(--line);display:inline-flex;align-items:center;justify-content:center;color:var(--ink);transition:all .25s}
.work-item:hover .arrow{background:var(--accent);border-color:var(--accent);color:#fff;transform:rotate(-8deg)}
.work-tags{display:flex;flex-wrap:wrap;gap:8px}
.work-tags span{font-size:11px;letter-spacing:.06em;text-transform:uppercase;padding:5px 11px;border:1px solid var(--line);border-radius:99px;color:var(--muted)}
.work-metric{font-size:13px;color:var(--accent);font-weight:600;letter-spacing:.02em}
.list-rows{position:relative;z-index:2}
.list-row{display:flex;justify-content:space-between;align-items:center;padding:28px 0;border-bottom:1px solid var(--line);font-size:28px;font-weight:500;letter-spacing:-.01em;text-transform:uppercase;transition:padding .25s,color .25s;cursor:default}
.card.dark .list-row{border-color:var(--line-dark)}
.list-row:hover{padding-left:16px;color:var(--accent)}
.list-row .arrow-sm{font-size:18px;color:var(--muted);transition:color .25s,transform .25s}
.list-row:hover .arrow-sm{color:var(--accent);transform:translate(4px,-4px)}
.list-row .meta{font-size:13px;color:var(--muted);text-transform:none;letter-spacing:.02em;font-weight:400}
.exp-row{display:grid;grid-template-columns:1fr 1fr auto;gap:24px;padding:24px 0;border-bottom:1px solid var(--line-dark);align-items:center}
.exp-row .company{font-size:18px;font-weight:500;color:#EFE7DA}
.exp-row .role{font-size:14px;color:#8A8278}
.exp-row .date{font-size:13px;color:#8A8278;text-align:right;white-space:nowrap}
.process-block{margin-bottom:56px;position:relative;z-index:2}
.process-block h3{font-size:22px;font-weight:600;letter-spacing:-.01em;margin-bottom:24px}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.step{background:rgba(255,255,255,.04);border:1px solid var(--line-dark);border-radius:14px;padding:22px}
.step .sn{font-size:11px;color:var(--accent);letter-spacing:.18em;font-weight:600;margin-bottom:10px}
.step .st{font-size:14px;font-weight:600;margin-bottom:6px;letter-spacing:.02em;text-transform:uppercase}
.step .sd{font-size:13px;color:var(--muted);line-height:1.55}
.tools-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;position:relative;z-index:2}
.tools-col h4{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:18px;font-weight:600}
.tools-col ul{list-style:none}
.tools-col li{padding:6px 0;font-size:14px;border-bottom:1px solid var(--line-dark)}
.samples-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;position:relative;z-index:2}
.sample-cat{background:#fff;border:1px solid var(--line);border-radius:18px;padding:28px;transition:all .25s}
.sample-cat:hover{border-color:var(--accent);transform:translateY(-3px)}
.sample-cat h4{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:16px}
.sample-cat ul{list-style:none;margin-bottom:18px}
.sample-cat li{font-size:13px;color:var(--muted);padding:5px 0;border-bottom:1px dashed var(--line)}
.sample-cat li:last-child{border:none}
.sample-cat a.folder{font-size:12px;color:var(--accent);letter-spacing:.06em;font-weight:600;display:inline-flex;align-items:center;gap:6px;text-transform:uppercase}
.contact-card{text-align:center;padding:120px 60px}
.contact-card h2{font-size:clamp(60px,9vw,140px);font-weight:700;letter-spacing:-.04em;line-height:.9;margin-bottom:32px}
.contact-card h2 em{color:var(--accent);font-style:italic;font-weight:400}
.contact-card .sub{font-size:15px;color:var(--muted);max-width:480px;margin:0 auto 40px}
.contact-card .email{font-size:24px;font-weight:500;border-bottom:1px solid var(--accent);padding-bottom:6px;color:var(--ink)}
.contact-card .links{margin-top:40px;display:flex;justify-content:center;gap:24px;font-size:13px;color:var(--muted)}
.contact-card .links a:hover{color:var(--accent)}
footer{text-align:center;color:var(--muted);font-size:12px;padding:32px 24px 48px;letter-spacing:.04em}
@media (max-width:960px){.card{padding:40px 28px;border-radius:22px}.work-grid,.steps,.tools-grid,.samples-grid{grid-template-columns:1fr;gap:18px}.results{grid-template-columns:repeat(2,1fr);gap:28px}.navlinks{display:none}.hero-bottom{flex-direction:column;align-items:flex-start;text-align:left;margin-top:32px;gap:24px}.list-row{font-size:20px;padding:20px 0}.exp-row{grid-template-columns:1fr;gap:6px}.exp-row .date{text-align:left}.ghost{font-size:90px}.hero-portrait{width:75%;max-width:340px}.hero-name{font-size:64px}.hero-socials{flex-direction:row;flex-wrap:wrap;align-items:flex-start}.hero-socials a{min-width:auto}}
</style>
</head>
<body>
<div class="page">

  <div class="card hero">
    <nav class="top">
      <span class="avail"><span class="dot"></span> {hero.available}</span>
      <div class="navlinks">
        <a href="#work">{hero.navWork}<sup>0{projects.length}</sup></a>
        <a href="#services">{hero.navServices}<sup>0{services.length}</sup></a>
        <a href="#experience">{hero.navExperience}<sup>0{experience.length}</sup></a>
        <a href="#contact">{hero.navContact}</a>
      </div>
      <a class="talk" href={`mailto:${hero.email}`}>{hero.ctaButton} ↗</a>
    </nav>
    <div class="hero-stage">
      <div class="hero-name">
        <span class="outline">{hero.nameFirst}</span> <span class="fill">{hero.nameLast}</span>
      </div>
      <div class="hero-portrait" aria-label="Andrea Clarizze Dalay"></div>
    </div>
    <div class="hero-bottom">
      <div class="hero-tagline">
        <div class="role">{hero.role}</div>
        {hero.tagline}
        <div><a class="cta" href={`mailto:${hero.email}`}>{hero.collaborateButton} ↗</a></div>
      </div>
      <div class="hero-socials">
        <a href={hero.linkedinUrl} target="_blank" rel="noopener"><span class="ico">in</span> LinkedIn</a>
        <a href={hero.driveUrl} target="_blank" rel="noopener"><span class="ico">◐</span> Drive</a>
        <a href={hero.githubUrl} target="_blank" rel="noopener"><span class="ico">{`{ }`}</span> GitHub</a>
        <a href={`mailto:${hero.email}`}><span class="ico">@</span> Email</a>
      </div>
    </div>
    <div class="results">
      {stats.map(s => (
        <div><div class="n"><Fragment set:html={s.value.replace(/^(\$?\d+\.?\d*)(.+)$/, '$1<em>$2</em>')} /></div><div class="lbl">{s.label}</div></div>
      ))}
    </div>
  </div>

  <div class="card" id="work">
    <div class="ghost" style="top:30px;right:-20px">PORTFOLIO</div>
    <div class="label"><span class="slash">/</span>SELECTED WORK</div>
    <div class="work-grid">
      {projects.map(p => (
        <div class="work-item">
          <div class="work-num">{p.number} — {p.category}</div>
          <div class="work-title">{p.title}</div>
          <div class="work-desc">{p.description}</div>
          <div class="work-tags">{p.tags.map(t => <span>{t}</span>)}</div>
          <div class="work-metric">{p.metric}</div>
          <div class="work-meta">
            <span>{p.label}</span>
            <a class="arrow" href={p.link} target="_blank" rel="noopener">↗</a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="card" id="services">
    <div class="ghost" style="top:30px;left:-20px">SERVICES</div>
    <div class="label"><span class="slash">/</span>SERVICES</div>
    <div class="list-rows">
      {services.map((s, i) => (
        <div class="list-row" style={i === services.length - 1 ? 'border-bottom:none' : ''}>
          <span>{s.title} <span class="meta">— {s.subtitle}</span></span>
          <span class="arrow-sm">↗</span>
        </div>
      ))}
    </div>
  </div>

  <div class="card dark" id="experience">
    <div class="ghost" style="top:30px;right:-20px">EXPERIENCE</div>
    <nav class="top" style="margin-bottom:48px">
      <div class="label" style="margin-bottom:0;color:#EFE7DA"><span class="slash">/</span>EXPERIENCE</div>
      <span style="color:var(--muted);font-size:13px">6+ years of experience</span>
    </nav>
    <div class="list-rows">
      {experience.map((e, i) => (
        <div class="exp-row" style={i === experience.length - 1 ? 'border-bottom:none' : ''}>
          <div class="company">{e.company}</div>
          <div class="role">{e.role}</div>
          <div class="date">{e.date}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="card dark">
    <div class="ghost" style="top:30px;left:-20px">PROCESS</div>
    <div class="label" style="color:#EFE7DA"><span class="slash">/</span>HOW I WORK</div>
    <div class="process-block">
      <h3>{process.title}</h3>
      <div class="steps">
        {process.steps.map(s => (
          <div class="step">
            <div class="sn">{s.number}</div>
            <div class="st">{s.title}</div>
            <div class="sd">{s.description}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="card">
    <div class="ghost" style="top:30px;right:-20px">SAMPLES</div>
    <div class="label"><span class="slash">/</span>READING LIST</div>
    <div class="samples-grid">
      {samples.map(s => (
        <div class="sample-cat">
          <h4>{s.title}</h4>
          <ul>{s.items.map(i => <li>{i}</li>)}</ul>
          <a class="folder" href={s.link} target="_blank" rel="noopener">Open Folder ↗</a>
        </div>
      ))}
    </div>
  </div>

  <div class="card dark">
    <div class="ghost" style="top:30px;left:-20px">STACK</div>
    <div class="label" style="color:#EFE7DA"><span class="slash">/</span>WHAT I WORK WITH</div>
    <div class="tools-grid">
      <div class="tools-col"><h4>Technical SEO</h4><ul>{tools.technical.map(t => <li>{t}</li>)}</ul></div>
      <div class="tools-col"><h4>Keyword & Strategy</h4><ul>{tools.keyword.map(t => <li>{t}</li>)}</ul></div>
      <div class="tools-col"><h4>Analytics</h4><ul>{tools.analytics.map(t => <li>{t}</li>)}</ul></div>
      <div class="tools-col"><h4>AI / GEO Stack</h4><ul>{tools.ai.map(t => <li>{t}</li>)}</ul></div>
    </div>
  </div>

  <div class="card contact-card" id="contact">
    <div class="ghost" style="top:30px;right:-20px">CONTACT</div>
    <div class="label"><span class="slash">/</span>CONTACT</div>
    <h2><Fragment set:html={contact.headline.replace(/(\w+)\.$/, '<em>$1.</em>')} /></h2>
    <div class="sub">{contact.subtitle}</div>
    <a class="email" href={`mailto:${contact.email}`}>{contact.email}</a>
    <div class="links">
      <a href={contact.linkedinUrl} target="_blank" rel="noopener">LinkedIn ↗</a>
      <a href={contact.driveUrl} target="_blank" rel="noopener">Drive Portfolio ↗</a>
      <a href={contact.githubUrl} target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </div>

  <footer>{footer}</footer>
</div>
</body>
</html>
